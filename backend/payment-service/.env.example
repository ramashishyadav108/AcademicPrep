# Database
MONGODB_URL=mongodb+srv://<user>:<password>@cluster.mongodb.net/StudyNotion

# Auth (shared secret — must match user-service)
JWT_SECRET=your_jwt_secret_here
PORT=4003

# Razorpay
RAZORPAY_KEY=rzp_test_xxxxxxxxxxxx
RAZORPAY_SECRET=your_razorpay_secret

# Inter-service URLs (used for fetching course/user details)
COURSE_SERVICE_URL=http://localhost:4002
USER_SERVICE_URL=http://localhost:4001

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# Environment
NODE_ENV=development
